# Copy this to .env for local development — never commit .env

# PostgreSQL (Railway internal URL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Shared secret between this API and the bot engine service
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BOT_ENGINE_SECRET=
